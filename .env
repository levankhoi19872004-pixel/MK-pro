# ============================================================
# KHO Minh Khai Pro V45 - Environment Example
# Copy file này thành .env khi chạy local hoặc khai báo biến trên Render.
# ============================================================

# APP
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
APP_NAME=KHO Minh Khai Pro V45
APP_URL=http://localhost:5000

# DATABASE - MongoDB Atlas / Render
# Ví dụ Atlas SRV:
MONGO_URI=mongodb://levankhoi19872004_db_user:Huyenlinh1@ac-0gypiez-shard-00-00.heszs0n.mongodb.net:27017,ac-0gypiez-shard-00-01.heszs0n.mongodb.net:27017,ac-0gypiez-shard-00-02.heszs0n.mongodb.net:27017/?ssl=true&replicaSet=atlas-f5ts1r-shard-0&authSource=admin&appName=Cluster0

# Nếu Windows/local bị lỗi DNS SRV, dùng connection string dạng mongodb:// từ Atlas:
# MONGO_URI=mongodb://<user>:<password>@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/kho_minh_khai_v45?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# SECURITY - BẮT BUỘC ĐỔI KHI DEPLOY THẬT
# Tạo chuỗi mạnh bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=f50c46f82a818d4d06142a12a04cae2bf8db742a71df051aaa76a576743173b5e690b98b24d5ac6dc75db2d9f99e8f066118e05cb2073b479754e7ca6fca9322
JWT_REFRESH_SECRET=a36ca5008d4664000d1f47307a5bfa768c36204372ed8e31afcfbf494f7c54bc129ecf4929017a3dba32ad6c65dbc4c237a88fcc7b23cb733b62b3610e0b1eee
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# CORS
# Để trống hoặc * khi chạy local. Production nên khai báo domain cụ thể.
CORS_ORIGIN=http://localhost:5000,http://localhost:3000

# RATE LIMIT
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# LEGACY / MIGRATION
# Production nên để false. Chỉ bật true khi debug/migration tạm thời.
ENABLE_LEGACY_JSON=false
AUTO_MIGRATE_JSON_TO_MONGO=false
LOAD_MONGO_CACHE_ON_START=false

# SWAGGER / DOCS
# Development/test: docs mở để dễ kiểm tra. Production: mặc định bắt buộc Bearer token.
ENABLE_SWAGGER=true
OPENAPI_JSON_PATH=docs/openapi.json
API_DOCS_REQUIRE_AUTH=false
API_DOCS_PUBLIC=false
DOCS_RATE_LIMIT_WINDOW_MS=900000
DOCS_RATE_LIMIT_MAX=60

# IMPORT / UPLOAD
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# TEST
# Khi chạy npm test có thể set NODE_ENV=test trong shell hoặc script CI.
# NODE_ENV=test
