# ============================================================
# KHO Minh Khai Pro V45 - Environment Example
# Copy file này thành .env khi chạy local hoặc khai báo biến trên Render.
# ============================================================

# APP
NODE_ENV=development
BIND_HOST=0.0.0.0
PORT=5000
LOG_LEVEL=info
APP_NAME=KHO Minh Khai Pro V45
APP_URL=http://localhost:5000

# DATABASE - MongoDB Atlas / Render
# Ví dụ Atlas SRV:
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kho_minh_khai_v45?retryWrites=true&w=majority

# Nếu Windows/local bị lỗi DNS SRV, dùng connection string dạng mongodb:// từ Atlas:
# MONGO_URI=mongodb://<user>:<password>@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/kho_minh_khai_v45?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# SECURITY - BẮT BUỘC ĐỔI KHI DEPLOY THẬT
# Tạo chuỗi mạnh bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_64_bytes_hex_access_secret
JWT_REFRESH_SECRET=change_me_generate_64_bytes_hex_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
# Để trống hoặc * khi chạy local. Production nên khai báo domain cụ thể.
CORS_ORIGIN=http://localhost:5000,http://localhost:3000

# RATE LIMIT
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# TRUST PROXY
# Render/nginx/reverse proxy: dùng 1 proxy hop mặc định.
# Set false nếu chạy trực tiếp không qua proxy.
TRUST_PROXY=1

# LEGACY / MIGRATION
# Production nên để false. Chỉ bật true khi debug/migration tạm thời.
ENABLE_LEGACY_JSON=false
AUTO_MIGRATE_JSON_TO_MONGO=false
LOAD_MONGO_CACHE_ON_START=false

# SWAGGER / DOCS
# Development/test: docs mở để dễ kiểm tra. Production: mặc định bắt buộc Bearer token.
ENABLE_SWAGGER=true
OPENAPI_JSON_PATH=docs/openapi.json
API_DOCS_REQUIRE_AUTH=false
API_DOCS_PUBLIC=false
DOCS_RATE_LIMIT_WINDOW_MS=900000
DOCS_RATE_LIMIT_MAX=60

# IMPORT / UPLOAD
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

IMPORT_MAX_FILE_SIZE=10485760
IMPORT_MAX_FILES=2
IMPORT_MAX_TOTAL_SIZE=20971520
IMPORT_MAX_ROWS=10000
IMPORT_MAX_COLUMNS=100
IMPORT_MAX_SHEETS=5
IMPORT_PARSE_TIMEOUT_MS=15000
IMPORT_PARSE_MAX_OLD_SPACE_MB=128
IMPORT_PREVIEW_ASYNC=true
IMPORT_JOB_TIMEOUT_MS=120000
IMPORT_JOB_MAX_OLD_SPACE_MB=256
# Số đơn bán xử lý trong một Mongo transaction khi commit import.
# 25 là mặc định an toàn; chỉ tăng sau khi đo transaction size và P95 trên production.
SALES_IMPORT_TX_CHUNK_SIZE=25
# Số dòng ghi mỗi batch vào import_session_rows.
IMPORT_SESSION_ROW_BATCH_SIZE=500
IMPORT_TMP_DIR=

# TEST
# Khi chạy npm test có thể set NODE_ENV=test trong shell hoặc script CI.
# NODE_ENV=test

# Mongo performance tuning
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_WRITE_CONCERN=majority
MONGOOSE_DEBUG=false
MONGOOSE_AUTO_INDEX=false
IMPORT_SESSION_TTL_SECONDS=3600

# RECONCILIATION / LEDGER AUDIT
AUTO_RECONCILIATION_JOB=true
RECONCILIATION_INTERVAL_MS=21600000
RECONCILIATION_MONEY_TOLERANCE=1000
RECONCILIATION_STOCK_TOLERANCE=0.0001

MOBILE_CATALOG_PRODUCTS_CACHE_MAX_ENTRIES=200

# Chỉ bật một lần khi chủ động migrate journal cũ sang arLedgers. Không bật mặc định production.
AUTO_BACKFILL_ARLEDGERS=false

IMPORT_PREVIEW_MAX_CONCURRENCY=2
IMPORT_PREVIEW_MAX_QUEUE=50

CORS_ALLOW_ALL=false
CORS_ALLOW_CREDENTIALS=false
JSON_BODY_LIMIT=5mb
URLENCODED_BODY_LIMIT=1mb
BACKUP_DIR=./backups
SYSTEM_MAINTENANCE_MODE=false

AUTH_REFRESH_RATE_LIMIT_MAX=60

REQUEST_IDEMPOTENCY_PROCESSING_TIMEOUT_MS=300000

AUTO_RECOVER_STALE_IMPORTS=true
# Giới hạn thời gian từng bước bootstrap; HTTP port đã mở trước các bước này.
STARTUP_DB_TIMEOUT_MS=30000
STARTUP_INDEX_TIMEOUT_MS=180000
STARTUP_BACKFILL_TIMEOUT_MS=180000
STARTUP_IMPORT_RECOVERY_TIMEOUT_MS=60000
IMPORT_STALE_SESSION_MS=900000

# Refresh token security: mặc định chỉ gửi bằng cookie HttpOnly.
ALLOW_REFRESH_TOKEN_IN_BODY=false
REFRESH_TOKEN_COOKIE_NAME=mk_refresh_token
REFRESH_TOKEN_COOKIE_SAMESITE=strict
# Production HTTPS tự bật secure; chỉ đặt false khi dev HTTP nội bộ.
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000

# Password policy for newly created/changed passwords.
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# Dangerous full-database JSON endpoint. Keep disabled; use backup instead.
ALLOW_SYSTEM_DATA_EXPORT=false

# Browser access token cookie (Bearer clients remain supported)
ACCESS_TOKEN_COOKIE_NAME=mk_access_token
ACCESS_TOKEN_COOKIE_MAX_AGE_MS=900000
ACCESS_TOKEN_COOKIE_SAMESITE=strict
# ACCESS_TOKEN_COOKIE_SECURE=true
# Required when public origin cannot be inferred from proxy headers
# PUBLIC_APP_ORIGIN=https://your-domain.example

# Automatic ledger/read-model consistency checks
RECONCILIATION_RUN_ON_START=true
RECONCILIATION_START_DELAY_MS=30000
RECONCILIATION_INTERVAL_MS=21600000

# Emergency rollback only; keep disabled during normal operation

# HOME DASHBOARD
FEATURE_HOME_DASHBOARD=true
# PHASE79A - MASTER ORDER ACCOUNTING CANARY
# false: extracted compatibility implementation (safe default)
# true: route through DeliverySettlementService domain boundary
USE_NEW_DELIVERY_SETTLEMENT=false

# Mặc định 0: luôn đọc MongoDB trực tiếp. Chỉ bật cache khi đã kiểm tra hiệu năng thực tế.
# Khi >0, cache dùng fingerprint updatedAt của các collection để tự vô hiệu khi dữ liệu đổi.
HOME_DASHBOARD_CACHE_TTL_MS=0
# DMS inventory reconciliation + App sale quota
# Keep enabled after Phase 50 deployment. Set false for emergency rollback.
ENABLE_DMS_APP_SALE_QUOTA=true
DMS_INVENTORY_UPLOAD_MAX_BYTES=10485760

# Phase80 enterprise expansion
DEFAULT_TENANT_ID=minh-khai
TENANT_MODE=single
# Chỉ đặt true sau khi backup, tenant:backfill, audit duplicate/index và smoke test staging.
TENANT_MIGRATION_CONFIRMED=false
ALLOW_ADMIN_TENANT_OVERRIDE=false
ENABLE_ENTERPRISE_CORE=true
ENABLE_PURCHASING=false
ENABLE_WAREHOUSE_ADVANCED=false
ENABLE_ANALYTICS_PROJECTIONS=false
# Online-first mobile policy. Do not queue new sales/debt commands when the network is down.
ENABLE_MOBILE_OFFLINE_SYNC=false
ENABLE_MOBILE_OFFLINE_QUEUE=false
# Temporary read/drain path for operations created by older releases. Disable after the queue is empty.
ENABLE_MOBILE_LEGACY_SYNC_DRAIN=true
MOBILE_LEGACY_SYNC_DRAIN_UNTIL=
MOBILE_CLIENT_TELEMETRY_ENABLED=true
MOBILE_CLIENT_TELEMETRY_SAMPLE_RATE=1
MOBILE_CLIENT_TELEMETRY_BATCH_SIZE=20
MOBILE_CLIENT_TELEMETRY_FLUSH_MS=60000
MOBILE_API_TIMEOUT_MS=15000
MOBILE_COMMAND_TIMEOUT_MS=30000
API_MONITOR_SAMPLE_SIZE=200
ENABLE_FIELD_OPERATIONS=false
ENABLE_DELIVERY_PLANNING=false
ENABLE_INTEGRATIONS=false
ENABLE_OUTBOX_WORKER=false
OUTBOX_POLL_INTERVAL_MS=15000
ENABLE_INTEGRATION_WORKER=false
INTEGRATION_POLL_INTERVAL_MS=30000
INTEGRATION_TIMEOUT_MS=15000
INTEGRATION_ALLOWED_HOSTS=
OUTBOX_WEBHOOK_ENDPOINT=
OUTBOX_WEBHOOK_PROVIDER=webhook
READINESS_MAX_PENDING_OUTBOX=10000
READINESS_MAX_FAILED_OUTBOX=100
READINESS_MAX_FAILED_INTEGRATIONS=100
ENABLE_REPORTING_PROJECTION_JOB=false
REPORTING_PROJECTION_INTERVAL_MS=3600000
PROJECTION_TENANT_ID=minh-khai


# SSE accounting invoice export (override config/sse-export.json when required)
SSE_SHEET_NAME=TỔNG
SSE_INVOICE_TYPE=3
SSE_INVOICE_SYMBOL=01_010824
SSE_WAREHOUSE_CODE=TP0101
SSE_CURRENCY_CODE=Vnd
SSE_EXCHANGE_RATE=1
SSE_TAX_CODE=00
SSE_DEBIT_ACCOUNT=13111
SSE_REVENUE_ACCOUNT=51111
SSE_COGS_ACCOUNT=63211
SSE_OUTPUT_TAX_ACCOUNT=333111
SSE_DISCOUNT_ACCOUNT=13121
SSE_SALESMAN_CODE=BANBUON
SSE_VAT_RATE=0.08
SSE_ALLOW_CANONICAL_CUSTOMER_CODE_FALLBACK=true
SSE_ALLOW_CANONICAL_PRODUCT_CODE_FALLBACK=true
SSE_MAX_ORDERS=20000
SSE_MAX_ROWS=100000

# Persistent background worker (run as a separate process/service)
BACKGROUND_JOB_CONCURRENCY=2
BACKGROUND_JOB_POLL_MS=1000
BACKGROUND_JOB_LEASE_MS=60000
BACKGROUND_JOB_MAX_OLD_SPACE_MB=512
BACKGROUND_JOB_RETRY_BASE_MS=2000
BACKGROUND_JOB_RETRY_MAX_MS=300000
BACKGROUND_JOB_RETENTION_MS=604800000
BACKGROUND_JOB_ARTIFACT_TTL_MS=86400000
BACKGROUND_JOB_COMPAT_WAIT_MS=600000
EXPORT_JOB_TIMEOUT_MS=600000
EXPORT_JOB_MAX_ATTEMPTS=3
EXPORT_IDEMPOTENCY_WINDOW_MS=300000
IMPORT_JOB_TIMEOUT_MS=120000
IMPORT_JOB_MAX_ATTEMPTS=2
IMPORT_JOB_INPUT_TTL_MS=21600000
IMPORT_COMMIT_JOB_TIMEOUT_MS=900000
RECONCILIATION_JOB_TIMEOUT_MS=1800000
RECONCILIATION_IDEMPOTENCY_WINDOW_MS=300000
# Worker command: npm run worker:background
