PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Render / cloud: use mongodb+srv
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kho_minh_khai_v43?retryWrites=true&w=majority

# Local Windows if SRV DNS fails: use standard mongodb:// connection string from Atlas
# MONGO_URI=mongodb://<user>:<password>@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/kho_minh_khai_v43?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# PHASE 1 SECURITY - bắt buộc đổi khi deploy thật
JWT_SECRET=please_change_to_a_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=please_change_to_another_long_random_secret_at_least_64_chars
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
API_RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_MAX=20
# CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com

# PHASE 2.6 PERFORMANCE
# Render production nên đặt false để server khởi động nhanh, không quét toàn bộ collection mỗi lần restart.
AUTO_MIGRATE_JSON_TO_MONGO=false
LOAD_MONGO_CACHE_ON_START=false

