# MK-Pro safe development/example configuration.
# Copy to .env and replace placeholder secrets locally. Never commit real credentials.
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/mkpro
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
BCRYPT_ROUNDS=12

# Production-safe feature defaults and explicitly governed jobs.
ENABLE_ENTERPRISE_CORE=false
ENABLE_MOBILE_OFFLINE_SYNC=false
ENABLE_MOBILE_OFFLINE_QUEUE=false
ENABLE_DMS_APP_SALE_QUOTA=true
# Scheduler ownership is explicit and fail-safe. Use web only for a single web instance.
SCHEDULED_JOB_OWNER=none
AUTO_RECONCILIATION_JOB=false
RECONCILIATION_RUN_ON_START=false
ENABLE_OUTBOX_WORKER=false
ENABLE_INTEGRATION_WORKER=false
ENABLE_REPORTING_PROJECTION_JOB=false
READINESS_REQUIRE_BACKGROUND_WORKER=false

# Intervals are used only when the corresponding job is explicitly enabled.
RECONCILIATION_INTERVAL_MS=21600000
RECONCILIATION_START_DELAY_MS=30000
OUTBOX_POLL_INTERVAL_MS=15000
INTEGRATION_POLL_INTERVAL_MS=30000
REPORTING_PROJECTION_INTERVAL_MS=3600000
