# MK-Pro safe development/example configuration.
# Copy to .env and replace placeholder secrets locally. Never commit real credentials.
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/mkpro
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
BCRYPT_ROUNDS=12

# Production-safe feature defaults and explicitly governed jobs.
ENABLE_MOBILE_OFFLINE_SYNC=false
ENABLE_MOBILE_OFFLINE_QUEUE=false
ENABLE_DMS_APP_SALE_QUOTA=true
AUTO_RECONCILIATION_JOB=true
