NODE_ENV=production
PORT=3000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/DATABASE

JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_REFRESH_SECRET
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
ALLOW_LEGACY_UNTYPED_TOKENS=false
ALLOW_REFRESH_TOKEN_IN_BODY=false

PUBLIC_APP_ORIGIN=https://erp.example.com
CORS_ORIGIN=https://erp.example.com
CORS_ALLOW_ALL=false
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY=1
ACCESS_TOKEN_COOKIE_SECURE=true
ACCESS_TOKEN_COOKIE_SAMESITE=strict
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAMESITE=strict

AUTO_ENSURE_MONGO_INDEXES=true
AUTO_RECONCILIATION_JOB=true
RECONCILIATION_RUN_ON_START=true
RECONCILIATION_START_DELAY_MS=30000
RECONCILIATION_INTERVAL_MS=21600000
AUTO_BACKFILL_ARLEDGERS=false
AUTO_RECOVER_STALE_IMPORTS=true

ALLOW_SYSTEM_RESET=false
SYSTEM_MAINTENANCE_MODE=false
ALLOW_SYSTEM_DATA_EXPORT=false
BACKUP_DIR=/var/lib/mk-pro/backups

# Emergency rollback only; keep disabled during normal operation

# HOME DASHBOARD
FEATURE_HOME_DASHBOARD=true
# Giữ 0 để số liệu luôn mới nhất. Có thể đặt 15000-30000 sau khi đo P95 trên production.
HOME_DASHBOARD_CACHE_TTL_MS=0
