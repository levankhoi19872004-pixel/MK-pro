function reportCenterColumnDescriptors(payload = {}) {
  return (payload.definition?.columns || []).map((column) => {
    if (Array.isArray(column)) return { key: column[0], label: column[1] || column[0] };
    return { key: column.key, label: column.label || column.key };
  }).filter((column) => cleanText(column.key));
}

async function buildReportCenterWorkbook(reportCode, query = {}, currentUser = {}) {
  const legacyExportType = cleanText(query.__legacyExportType || '');
  const payload = await ReportCenterService.run(reportCode, {
    ...query,
    __exportAll: true,
    __legacyBridge: legacyExportType ? { legacyExportType, mappedReportCode: reportCode, bridgedToReportCenter: true } : null
  }, currentUser);
  const columns = reportCenterColumnDescriptors(payload);
  const headers = columns.map((column) => column.label);
  const rows = (payload.rows || []).map((row, idx) => {
    const output = { STT: idx + 1 };
    for (const column of columns) output[column.label] = row[column.key] ?? '';
    return output;
  });
  const sheetName = cleanText(payload.definition?.title || reportCode).slice(0, 31) || 'BaoCao';
  return reportWorkbook(reportCode, sheetName, ['STT', ...headers], rows, query, payload.sourceNote);
}


function getExportTypes() {
  return [...new Set([...exportRepository.getExportTypes(), 'invoice-orders', 'vatInvoiceTT78', 'vat-non-invoice-orders', 'sse-invoice-orders', 'sse-invoice-errors', ...Object.keys(LEGACY_EXPORT_TYPE_TO_REPORT_CODE)])].sort();
}

async function exportToExcel(type, query = {}, currentUser = {}) {
  const normalizedType = String(type || '').trim();
  if (['sse-invoice-orders', 'sseInvoiceOrders'].includes(normalizedType)) {
    return sseInvoiceExportService.buildSseInvoiceWorkbook(query, currentUser);
  }
  if (['sse-invoice-errors', 'sseInvoiceErrors'].includes(normalizedType)) {
    return sseInvoiceExportService.buildSseErrorReportWorkbook(query, currentUser);
  }
  if (['invoice-orders', 'invoiceOrders'].includes(normalizedType)) {
    const invoiceType = normalizeInvoiceType(query.invoiceType);
    if (!invoiceType) return { error: 'invoiceType chỉ nhận VAT hoặc NON_VAT', status: 400 };
    return invoiceType === INVOICE_TYPES.VAT
      ? buildVatInvoiceTT78Workbook(query, currentUser)
      : buildVatNonInvoiceOrdersWorkbook(query, currentUser);
  }
  if (['vatInvoiceTT78', 'vat-invoice-tt78', 'hoa-don-vat-tt78'].includes(normalizedType)) {
    return buildVatInvoiceTT78Workbook(query, currentUser);
  }
  if (['vat-non-invoice-orders', 'vatNonInvoiceOrders'].includes(normalizedType)) {
    return buildVatNonInvoiceOrdersWorkbook(query, currentUser);
  }
  const reportCode = reportCodeForLegacyExport(normalizedType);
  if (reportCode) {
    return buildReportCenterWorkbook(reportCode, { ...query, __legacyExportType: normalizedType }, currentUser);
  }
  const rows = await exportRepository.findForExport(type, query);
  if (!rows) return { error: 'Loại dữ liệu export không hợp lệ', status: 400 };
  const buffer = await buildWorkbook({ type, rows });
  const safeType = String(type || 'data').replace(/[^a-zA-Z0-9_-]/g, '-');
  return { buffer, rows: rows.length, fileName: `${safeType}-export-${dateUtil.todayVN()}.xlsx` };
}

