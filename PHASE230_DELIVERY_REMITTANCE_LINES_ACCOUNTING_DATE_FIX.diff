+async function listDeliveryCashSubmissions(query = {}) {
+  const filter = {};
+  if (query.deliveryDate || query.date) filter.deliveryDate = dateOnly(query.deliveryDate || query.date);
+  if (pickDeliveryStaffCode(query) || query.delivery) filter.deliveryStaffCode = String(pickDeliveryStaffCode(query) || query.delivery).trim();
+  let rows = await deliveryCashSubmissionRepository.findAll(filter, { sort: { deliveryDate: -1, createdAt: -1, code: -1 }, limit: query.limit || 500 });
+  const q = normalizeText(query.q || query.search || '');
+  if (q) rows = rows.filter((row) => matchQuery(row, q));
+  if (!rows.length) return { submissions: [] };
+
+  const ids = rows.map((row) => String(row.id || '').trim()).filter(Boolean);
+  const codes = rows.map((row) => String(row.code || '').trim()).filter(Boolean);
+  const sourceFilter = [];
+  if (ids.length) sourceFilter.push({ sourceSubmissionId: { $in: ids } });
+  if (codes.length) sourceFilter.push({ sourceSubmissionCode: { $in: codes } });
+  const shortageRows = sourceFilter.length
+    ? await deliveryCashShortageRepository.findAll({ $or: sourceFilter }, { limit: Math.min(1000, rows.length * 3) })
+    : [];
+  const shortageBySource = new Map();
+  for (const shortage of shortageRows) {
+    const keys = [shortageMapKey(shortage.sourceSubmissionId, ''), shortageMapKey('', shortage.sourceSubmissionCode)].filter(Boolean);
+    for (const key of keys) {
+      if (!shortageBySource.has(key)) shortageBySource.set(key, {});
+      shortageBySource.get(key)[canonicalFundType(shortage.fundType)] = shortage;
+    }
+  }
+
+  const ledgerOr = [];
+  if (ids.length) ledgerOr.push({ sourceId: { $in: ids } }, { referenceId: { $in: ids } });
+  if (codes.length) ledgerOr.push({ sourceCode: { $in: codes } }, { referenceCode: { $in: codes } });
+  const relatedLedgers = ledgerOr.length
+    ? await fundLedgerRepository.findAll({ sourceType: 'DELIVERY_CASH_SUBMISSION', $or: ledgerOr }, { limit: Math.min(2000, rows.length * 8) })
+    : [];
+  const ledgersBySubmission = new Map();
+  for (const ledger of relatedLedgers) {
+    for (const identity of [ledger.sourceId, ledger.sourceCode, ledger.referenceId, ledger.referenceCode].map((value) => String(value || '').trim()).filter(Boolean)) {
+      if (!ledgersBySubmission.has(identity)) ledgersBySubmission.set(identity, []);
+      ledgersBySubmission.get(identity).push(ledger);
+    }
+  }
+
+  rows = rows.map((row) => {
+    const shortages = shortageBySource.get(shortageMapKey(row.id, '')) || shortageBySource.get(shortageMapKey('', row.code)) || {};
+    const persistedLines = normalizeRemittanceLines(row.remittanceLines, { submissionIdentity: row.id || row.code, makeId });
+    const legacyLedgers = ledgersBySubmission.get(String(row.id || '').trim()) || ledgersBySubmission.get(String(row.code || '').trim()) || [];
+    let remittanceLines = persistedLines;
+    let legacyDerived = false;
+    if (!remittanceLines.length && legacyLedgers.length) {
+      legacyDerived = true;
+      remittanceLines = normalizeRemittanceLines(legacyLedgers.map((ledger, index) => ({
+        lineId: ledger.sourceLineId || `LEGACY-${ledger.id || ledger.code || index + 1}`,
+        method: ledger.fundType,
+        amount: ledger.amount,
+        remittanceDate: ledger.remittanceDate || ledger.accountingDate || ledger.date,
+        status: 'confirmed',
+        confirmedAt: ledger.createdAt,
+        confirmedBy: ledger.createdBy,
+        fundLedgerId: ledger.id || ledger.code,
+        idempotencyKey: ledger.idempotencyKey,
+        bankAccountCode: ledger.bankAccountCode || ledger.account,
+        bankReference: ledger.bankReference,
+        legacyDerived: true
+      })), { submissionIdentity: row.id || row.code, makeId });
+    } else if (!remittanceLines.length && !row.fundPosted) {
+      legacyDerived = true;
+      remittanceLines = linesFromLegacyAmounts(row, {
+        submissionIdentity: row.id || row.code,
+        makeId,
+        defaultRemittanceDate: '',
+        defaultStatus: 'draft'
+      });
+    }
+    const enriched = applyLineSummary(row, remittanceLines, {
+      makeId,
+      forceStatus: row.status,
+      forceFundPosted: row.fundPosted
+    });
+    return {
+      ...enriched,
+      legacyDerived,
+      cashShortage: shortages.cash || null,
+      bankShortage: shortages.bank || null
+    };
+  });
+  return { submissions: rows };
+}
