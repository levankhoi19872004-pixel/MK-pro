+  border-radius: 16px 16px 0 0;
+  background: #ffffff;
+  color: inherit;
+  padding: 12px;
+  text-align: left;
+}
+.m-order-card-header {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 10px;
+  align-items: start;
+  margin-bottom: 8px;
+}
+.m-order-title {
+  min-width: 0;
+}
+.m-order-title b {
+  display: block;
+  font-size: 16px;
