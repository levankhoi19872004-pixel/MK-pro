function renderTodayOrders(items = state.orders.rows, summary = state.orders.summary) {
  state.orders.rows = Array.isArray(items) ? items : [];
  const serverOrders = state.orders.rows;
  const selectedDate = String(orderDateFilter?.value || todayValue());
  const pendingForDate = state.sync.pendingOrders.filter((order) => !selectedDate || String(order.date || '').slice(0, 10) === selectedDate);
  const allDisplayOrders = [...pendingForDate, ...serverOrders];
  const displayOrders = allDisplayOrders.filter(orderMatchesSearchText).filter(orderMatchesDisplayFilter);
  const totalAmount = Number(summary?.totalAmount ?? serverOrders.reduce((sum, order) => sum + Number(order.totalAmount || 0), 0));
  const paidAmount = Number(summary?.paidAmount ?? serverOrders.reduce((sum, order) => sum + Number(order.paidAmount || 0), 0));
  const debtAmount = Number(summary?.debtAmount ?? serverOrders.reduce((sum, order) => sum + Number(order.debtAmount || 0), 0));
  const orderCount = Number(summary?.orderCount ?? serverOrders.length);

  document.getElementById('todayRevenue').textContent = money(totalAmount);
  document.getElementById('todayOrderCount').textContent = String(orderCount);
  document.getElementById('todayPaid').textContent = money(paidAmount);
  document.getElementById('todayDebt').textContent = money(debtAmount);
  if (orderFilterResultCount) orderFilterResultCount.textContent = `${displayOrders.length} đơn`;
  if (orderLoadMoreBtn) orderLoadMoreBtn.hidden = !state.orders.hasMore || orderStatusFilterValue() === 'pending_sync';

  if (!displayOrders.length) {
    const hasAnyRows = allDisplayOrders.length > 0;
    renderMobileListState(todayOrders, {
      state: 'empty',
      baseClass: 'order-list',
      title: hasAnyRows ? 'Không có đơn phù hợp bộ lọc' : 'Chưa có đơn trong ngày đã chọn',
      detail: hasAnyRows ? 'Hãy đổi từ khóa hoặc trạng thái hiển thị.' : 'Đơn online và đơn chờ đồng bộ sẽ xuất hiện tại đây.'
    });
    return;
  }

  todayOrders.className = 'order-list mobile-order-list';
  const renderOrderCard = (order) => buildOrderCardsHtml([order], {
    escapeHtml,
    money,
    formatDate: formatDisplayDate
  });
  todayOrderListRenderer.render(displayOrders, renderOrderCard);

}



function upsertTodayOrder(order = {}) {
  state.orders.rows = upsertOrder(state.orders.rows, order);
  renderTodayOrders(state.orders.rows, state.orders.summary);
}

async function loadTodayOrders(options = {}) {
  const append = options.append === true;
  const force = options.force === true;
  const queryKey = currentOrderQueryKey();
  if (append && state.orders.loadedKey !== queryKey) return loadTodayOrders({ reset: true, force: true });
  if (state.orders.loading) return;
  if (append && !state.orders.hasMore) return;
  if (state.orders.loaded && state.orders.loadedKey === queryKey && !force && !append) {
    renderTodayOrders(state.orders.rows, state.orders.summary);
    return;
  }

  const requestSeq = ++state.orders.requestSeq;
  const nextPage = append ? state.orders.page + 1 : 1;
  state.orders.loading = true;
  setButtonBusy(orderLoadMoreBtn, true, 'Đang tải...');
  try {
    if (!append) {
      renderMobileListState(todayOrders, {
        state: 'loading',
        baseClass: 'order-list',
        title: 'Đang tải đơn hàng...'
      });
    }
    const data = await mobileApi.getMySalesOrders({
      page: nextPage,
      limit: ORDER_PAGE_LIMIT,
      date: String(orderDateFilter?.value || todayValue()),
      q: String(orderSearch?.value || '').trim(),
      requestKey: 'mobile-sales-orders',
      cancelPrevious: !append
    });
    if (requestSeq !== state.orders.requestSeq) return;
    const rawItems = data.items || [];
    const scopedItems = filterOrdersForCurrentSalesUser(rawItems);
    state.orders.page = Number(data.pagination?.page || nextPage);
    state.orders.hasMore = Boolean(data.pagination?.hasMore);
    state.orders.summary = data.summary || state.orders.summary || {};
    state.orders.rows = append ? mergeOrderPages(state.orders.rows, scopedItems) : scopedItems;
    state.orders.loaded = true;
    state.orders.loadedKey = queryKey;
    renderTodayOrders(state.orders.rows, state.orders.summary);
    if (orderLoadMoreBtn) orderLoadMoreBtn.hidden = !state.orders.hasMore || orderStatusFilterValue() === 'pending_sync';
    if (rawItems.length !== scopedItems.length) {
      console.warn('[sales:owner]', currentSalesStaffCode(), rawItems.length, scopedItems.length);
    }
  } catch (err) {
    if (requestSeq !== state.orders.requestSeq || err?.code === 'REQUEST_ABORTED') return;
    if (!append) {
      state.orders.loaded = false;
      state.orders.loadedKey = '';
      renderMobileListState(todayOrders, {
        state: 'error',
        baseClass: 'order-list',
        title: 'Không tải được đơn hàng',
        detail: err.message || 'Vui lòng kiểm tra kết nối và thử lại.',
        retryAction: 'orders'
      });
    } else {
      announceMobileStatus(err.message || 'Không tải thêm được đơn hàng', 'error', { persist: true });
    }
  } finally {
    if (requestSeq === state.orders.requestSeq) state.orders.loading = false;
    setButtonBusy(orderLoadMoreBtn, false);
  }
}

