+  const clauses = [];
+  if (filters.fundType) clauses.push({ fundType: filters.fundType });
+  if (filters.account) {
+    clauses.push({
+      $or: [
+        { account: filters.account },
+        { fundCode: filters.account },
+        { bankAccountCode: filters.account }
