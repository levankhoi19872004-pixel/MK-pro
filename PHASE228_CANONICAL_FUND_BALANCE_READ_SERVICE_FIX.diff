+      in: {
+        $cond: [
+          { $gt: [{ $strLenCP: '$$explicitDate' }, 0] },
+          '$$explicitDate',
+          {
+            $dateToString: {
+              date: '$$createdAtDate',
+              format: '%Y-%m-%d',
+              timezone: timezone || DEFAULT_TIMEZONE,
+              onNull: ''
