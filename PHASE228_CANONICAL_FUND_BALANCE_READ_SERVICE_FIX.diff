+    $switch: {
+      branches: [
+        { case: { $in: [explicit, ['out', 'chi', 'expense', 'payment']] }, then: 'out' },
+        { case: { $in: [explicit, ['in', 'thu', 'receipt', 'income']] }, then: 'in' },
+        { case: { $regexMatch: { input: fallback, regex: 'out|expense|payment|chi|withdraw|transfer[_\\s-]*out' } }, then: 'out' }
