+ */
+function fundLedgerCanonicalFilter(extra = {}) {
+  const canonical = {
+    ...activeDocumentFilter(),
+    active: { $ne: false },
+    isDeleted: { $ne: true },
+    deletedAt: { $in: [null, ''] },
+    status: { $nin: BLOCKED_STATUSES },
+    reversed: { $ne: true },
+    isReversal: { $ne: true },
+    reversalOf: { $in: [null, ''] },
