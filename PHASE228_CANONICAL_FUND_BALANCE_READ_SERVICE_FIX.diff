+  if (!dateFrom || !dateTo) {
+    const error = new Error('Khoảng ngày sổ quỹ không hợp lệ');
+    error.status = 400;
+    error.code = 'INVALID_FUND_DATE_RANGE';
+    throw error;
+  }
+  if (dateFrom > dateTo) {
+    const error = new Error('Từ ngày phải nhỏ hơn hoặc bằng Đến ngày');
+    error.status = 400;
+    error.code = 'INVALID_FUND_DATE_RANGE';
+    throw error;
+  }
